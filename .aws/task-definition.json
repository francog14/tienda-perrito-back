{
  "containerDefinitions": [
    {
      "name": "backend-container",
      "image": "193419803239.dkr.ecr.us-east-1.amazonaws.com/tienda-perrito-backend:latest",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 3001,
          "hostPort": 3001,
          "protocol": "tcp",
          "name": "backend-container-3001-tcp",
          "appProtocol": "http"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "DB_NAME",
          "value": "tienda_perritos"
        },
        {
          "name": "DB_HOST",
          "value": "10.0.2.5"
        },
        {
          "name": "DB_USER",
          "value": "alumno"
        },
        {
          "name": "DB_PASSWORD",
          "value": "alumno123"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/tarea-backend",
          "awslogs-create-group": "true",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ],
  "family": "tarea-backend",
  "taskRoleArn": "arn:aws:iam::193419803239:role/LabRole",
  "executionRoleArn": "arn:aws:iam::193419803239:role/LabRole",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "512",
  "memory": "1024",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  }
}
